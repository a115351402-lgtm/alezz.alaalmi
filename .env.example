# Copy this file to `.env` for local testing with `npx vercel dev`.
# `.env` is gitignored — the real key never gets committed.
#
# On production: add the same variables in
# Vercel Dashboard → your project → Settings → Environment Variables
#
# Get your key from: https://my.carapis.com (keys start with car_)

AUTO_API_KEY=ضع_مفتاح_carapis_هنا
# Optional override (default: https://api.carapis.com/apix/catalog_api)
# CARAPIS_URL=

# ── Supabase (server-side only, used by /api/*.mjs) ──────────────
# SERVICE ROLE KEY = full DB access, BYPASSES Row Level Security.
# Never expose it client-side and never commit it. Server env only.
# Get it from: Supabase Dashboard → Settings → API → service_role
SUPABASE_URL=https://rkdwqptiaknoedmsmrjk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ضع_مفتاح_service_role_هنا
# Note: the PUBLIC (publishable) key is intentionally hardcoded in
# supabase-client.js — it is safe to expose; RLS protects the data.
